# ── MongoDB ──
# Local: mongodb://localhost:27017
# Production: mongodb+srv://<username>:<password>@cluster.mongodb.net
MONGODB_URL=mongodb://localhost:27017
DATABASE_NAME=indiawebprogrammers

# ── JWT ──
# Generate: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=change-this-to-a-secure-random-string-in-production
JWT_REFRESH_SECRET_KEY=change-this-to-another-secure-random-string-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ──
# Supports any of:
#   "http://localhost:3000"
#   "http://localhost:3000,https://example.com"
#   '["http://localhost:3000","https://example.com"]'
CORS_ORIGINS=["http://localhost:3000"]

# ── Environment ──
ENVIRONMENT=development
HOST=0.0.0.0
PORT=8000
DEBUG=false
LOG_LEVEL=INFO
